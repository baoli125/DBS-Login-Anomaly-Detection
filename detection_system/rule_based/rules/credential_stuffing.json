{
  "id": "R-CRED-STUFF",
  "name": "Credential Stuffing Detection",
  "enabled": true,
  "priority": "high",
  "scope": "ip",
  "entity_key": "src_ip",
  "window": { "type": "sliding", "seconds": 300 },
  "condition": {
    "type": "and",
    "clauses": [
      { "metric": "failed_attempts_5m", "op": ">=", "value": 5 },
      { "metric": "unique_users", "op": ">=", "value": 3 },
      { "metric": "success_rate", "op": "<", "value": 0.2 }
    ]
  },
  "action": {
    "type": "staged",
    "stages": [
      {
        "threshold": 10,
        "action": "alert",
        "params": { "message": "Possible credential stuffing from IP" }
      },
      {
        "threshold": 30,
        "action": "temp_block",
        "params": { "duration_s": 7200 }
      }
    ]
  },
  "severity": "high",
  "cooldown_seconds": 0,
  "ttl_seconds": 10800,
  "evidence_fields": ["src_ip", "failed_attempts_5m", "unique_users", "success_rate", "sample_usernames"]
}